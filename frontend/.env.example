# Strapi backend URL (Render deployment)
NEXT_PUBLIC_STRAPI_URL=https://<render-app>.onrender.com

# Server-side base URL Next.js uses to call Strapi (can be internal/private URL, e.g. Docker service name)
STRAPI_INTERNAL_URL=https://<render-app>.onrender.com

# Server-only — Strapi API token (Custom, create-only) for order/booking/contact-lead/newsletter-subscriber.
# NEVER prefix with NEXT_PUBLIC_, never expose to the client bundle.
STRAPI_API_TOKEN=
