{
  "kind": "collectionType",
  "collectionName": "testimonial_topics",
  "info": {
    "singularName": "testimonial-topic",
    "pluralName": "testimonial-topics",
    "displayName": "Testimonial Topic",
    "description": "Ngu canh cho testimonial"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
