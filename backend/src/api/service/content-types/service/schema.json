{
  "kind": "collectionType",
  "collectionName": "services",
  "info": {
    "singularName": "service",
    "pluralName": "services",
    "displayName": "Service",
    "description": "Dich vu / treatment / package"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "eyebrow": {
      "type": "string"
    },
    "intro": {
      "type": "text"
    },
    "body": {
      "type": "blocks"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "outcomeSummary": {
      "type": "text"
    },
    "duration": {
      "type": "string"
    },
    "format": {
      "type": "string"
    },
    "followUp": {
      "type": "string"
    },
    "suitableFor": {
      "type": "text"
    },
    "primaryCta": {
      "type": "component",
      "component": "shared.cta",
      "repeatable": false
    },
    "secondaryCta": {
      "type": "component",
      "component": "shared.cta",
      "repeatable": false
    },
    "price": {
      "type": "string"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::service-category.service-category",
      "inversedBy": "services"
    },
    "skinConcerns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skin-concern.skin-concern",
      "inversedBy": "services"
    },
    "relatedResults": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skin-result.skin-result",
      "inversedBy": "relatedServices"
    },
    "relatedFaqs": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::faq.faq",
      "inversedBy": "relatedServices"
    },
    "featuredOnHome": {
      "type": "boolean",
      "default": false
    },
    "tagline": {
      "type": "string"
    },
    "priceNote": {
      "type": "string"
    },
    "flagship": {
      "type": "boolean",
      "default": false
    },
    "forWhom": {
      "type": "json"
    },
    "problems": {
      "type": "json"
    },
    "steps": {
      "type": "json"
    },
    "includes": {
      "type": "json"
    },
    "results": {
      "type": "json"
    }
  }
}
