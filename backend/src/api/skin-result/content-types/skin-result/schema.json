{
  "kind": "collectionType",
  "collectionName": "skin_results",
  "info": {
    "singularName": "skin-result",
    "pluralName": "skin-results",
    "displayName": "Skin Result",
    "description": "Before/after, case study"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "beforeImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "afterImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "timeframe": {
      "type": "string"
    },
    "caseSummary": {
      "type": "text"
    },
    "treatmentSteps": {
      "type": "blocks"
    },
    "disclaimer": {
      "type": "text"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "skinConcerns": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::skin-concern.skin-concern",
      "inversedBy": "skinResults"
    },
    "resultType": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::result-type.result-type",
      "inversedBy": "skinResults"
    },
    "relatedServices": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service.service",
      "mappedBy": "relatedResults"
    }
  }
}
