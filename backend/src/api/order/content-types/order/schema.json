{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Don mua tu checkout"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "customerName": {
      "type": "string",
      "required": true
    },
    "customerPhone": {
      "type": "string",
      "required": true
    },
    "customerEmail": {
      "type": "string"
    },
    "province": {
      "type": "string"
    },
    "district": {
      "type": "string"
    },
    "ward": {
      "type": "string"
    },
    "street": {
      "type": "string"
    },
    "note": {
      "type": "text"
    },
    "items": {
      "type": "json"
    },
    "itemCount": {
      "type": "integer"
    },
    "subtotal": {
      "type": "decimal"
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["cod", "bank", "staff"]
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "confirmed", "cancelled"],
      "default": "pending"
    }
  }
}
