{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimonial",
    "description": "Social proof / review"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "caseType": {
      "type": "string"
    },
    "stars": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5
    },
    "quote": {
      "type": "text"
    },
    "photo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "improvement": {
      "type": "string"
    },
    "beforeState": {
      "type": "string"
    },
    "afterState": {
      "type": "string"
    },
    "duration": {
      "type": "string"
    },
    "expertNote": {
      "type": "text"
    },
    "featured": {
      "type": "boolean",
      "default": false
    },
    "sourceLabel": {
      "type": "string"
    },
    "sourceUrl": {
      "type": "string"
    },
    "relatedServices": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service.service"
    },
    "topic": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::testimonial-topic.testimonial-topic",
      "inversedBy": "testimonials"
    },
    "relatedProducts": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "inversedBy": "testimonials"
    }
  }
}
