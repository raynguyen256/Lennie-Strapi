{
  "kind": "collectionType",
  "collectionName": "product_reviews",
  "info": {
    "singularName": "product-review",
    "pluralName": "product-reviews",
    "displayName": "Product Review",
    "description": "Danh gia san pham theo tung SKU"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "stars": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5,
      "required": true
    },
    "comment": {
      "type": "text",
      "required": true
    },
    "product": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product.product",
      "inversedBy": "productReviews"
    },
    "verified": {
      "type": "boolean",
      "default": true
    }
  }
}
